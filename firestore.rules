rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'xp', 'createdAt', 'updatedAt'])
        && data.keys().size() == 6
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.role in ['graduate', 'employer']
        && data.xp is int
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidEnrollment(data) {
      return data.keys().hasAll(['courseId', 'enrolledAt', 'progress'])
        && data.keys().size() == 3
        && data.courseId is string && data.courseId.size() <= 128
        && data.enrolledAt == request.time
        && data.progress is number;
    }

    function isValidAnalysis(data) {
      return data.keys().hasAll(['feedback', 'score', 'suggestedRoles', 'timestamp'])
        && data.keys().size() == 4
        && data.feedback is string && data.feedback.size() <= 10000
        && data.score is int && data.score >= 0 && data.score <= 100
        && data.suggestedRoles is list && data.suggestedRoles.size() <= 10
        && data.timestamp == request.time;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      // No list on all users
      
      allow create: if isOwner(userId) 
        && isValidUser(incoming());
        
      allow update: if isOwner(userId)
        && incoming().email == existing().email // Immutable email
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          // Action: Update Profile
          (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'updatedAt'])) ||
          // Action: Gain XP
          (incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'updatedAt']))
        );

      // Enrollments subcollection
      match /enrollments/{enrollmentId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) 
          && isValidEnrollment(incoming());
        allow update: if isOwner(userId)
          && incoming().enrolledAt == existing().enrolledAt
          && incoming().courseId == existing().courseId
          && incoming().diff(existing()).affectedKeys().hasOnly(['progress']);
      }

      // Resume Analyses subcollection
      match /resumeAnalyses/{analysisId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) 
          && isValidAnalysis(incoming());
        // No updates to past analyses
      }
    }
  }
}
